            "description": "text/event-stream",
            "content": {
              "text/event-stream": {
                "schema": {
                  "type": "string"
                }
              }
            },
            "headers": {
              "X-StockPair-API-Version": {
                "$ref": "#/components/headers/StockPairApiVersion"
              }
            }
          }
        }
      }
    },
    "/api/robinhood/capabilities": {
