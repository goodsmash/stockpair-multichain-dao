    },
    "/api/robinhood/gas": {
      "get": {
        "summary": "Return current gas price plus Nitro L2/L1 data-fee guidance",
        "responses": {
          "200": {
            "description": "Return current gas price plus Nitro L2/L1 data-fee guidance",
