              "enum": [
                "unknown",
                "too-new",
                "active-evidence",
                "watch",
                "dormant-candidate"
              ]
            }
          },
          {
            "name": "role",
            "in": "query",
            "schema": {
              "type": "string",
              "maxLength": 80
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 500
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Selector, probe, activity and dormancy evidence without ownership or recoverability claims",
            "headers": {
              "X-StockPair-API-Version": {
                "$ref": "#/components/headers/StockPairApiVersion"
              }
            }
          }
        }
      }
