    },
    "/api/robinhood/node": {
      "get": {
        "summary": "Return documented Nitro, ArbOS, sequencer-feed and node-resource posture",
        "responses": {
          "200": {
            "description": "Return documented Nitro, ArbOS, sequencer-feed and node-resource posture",
            "headers": {
              "X-StockPair-API-Version": {
                "$ref": "#/components/headers/StockPairApiVersion"
              }
            }
          }
        }
      }
    },
    "/api/robinhood/finality": {
      "get": {
        "summary": "Conservatively assess a transaction using the provider finalized tag",
        "parameters": [
          {
            "name": "transactionHash",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "pattern": "^0x[0-9a-fA-F]{64}$"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Finality model and optional transaction status",
            "headers": {
              "X-StockPair-API-Version": {
                "$ref": "#/components/headers/StockPairApiVersion"
              }
            }
          }
        }
      }
    },
    "/api/robinhood/stock-token/{address}": {
      "get": {
        "summary": "Inspect ERC-8056 corporate-action state and fail-closed oracle/sequencer safety",
        "parameters": [
          {
            "name": "address",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "pattern": "^0x[0-9a-fA-F]{40}$"
            }
          },
          {
            "name": "feed",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "pattern": "^0x[0-9a-fA-F]{40}$"
            }
          },
          {
            "name": "sequencerFeed",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "pattern": "^0x[0-9a-fA-F]{40}$"
            }
          },
          {
            "name": "wallet",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "pattern": "^0x[0-9a-fA-F]{40}$"
            }
          },
          {
            "name": "heartbeatSeconds",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 604800
            }
          },
          {
            "name": "gracePeriodSeconds",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 0,
              "maximum": 86400,
              "default": 3600
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Sanitized stock-token, corporate-action, oracle, sequencer and execution assessment",
            "headers": {
              "X-StockPair-API-Version": {
                "$ref": "#/components/headers/StockPairApiVersion"
              }
            }
          }
        }
      }
    },
    "/api/robinhood/messaging-plan": {
      "get": {
        "summary": "Generate an unsigned canonical L1\u2194L2 message plan",
        "parameters": [
          {
            "name": "direction",
            "in": "query",
            "required": true,
            "schema": {
              "enum": [
                "l1-to-l2",
                "l2-to-l1"
              ]
            }
          },
          {
            "name": "target",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "pattern": "^0x[0-9a-fA-F]{40}$"
            }
          },
          {
            "name": "data",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "pattern": "^0x(?:[0-9a-fA-F]{2})*$"
            }
          },
          {
            "name": "from",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "pattern": "^0x[0-9a-fA-F]{40}$"
            }
          },
          {
            "name": "l2CallValue",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "pattern": "^[0-9]+$"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Unsigned, user-signature-required retryable or Outbox plan",
            "headers": {
              "X-StockPair-API-Version": {
                "$ref": "#/components/headers/StockPairApiVersion"
              }
            }
          }
        }
      }
    },
    "/api/robinhood/bridge-plan": {
      "get": {
        "summary": "Generate an unsigned canonical asset-bridge plan",
        "parameters": [
          {
            "name": "direction",
            "in": "query",
            "required": true,
            "schema": {
              "enum": [
                "l1-to-l2",
                "l2-to-l1"
              ]
            }
          },
          {
            "name": "token",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "pattern": "^0x[0-9a-fA-F]{40}$"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Canonical gateway plan with timing and blockers",
            "headers": {
              "X-StockPair-API-Version": {
                "$ref": "#/components/headers/StockPairApiVersion"
              }
            }
          }
        }
      }
    },
    "/api/radar/deployer-reputation": {
      "get": {
        "summary": "Return bounded, evidence-limited deployer reputation",
        "responses": {
          "200": {
            "description": "Read-only evidence response",
            "headers": {
              "X-StockPair-API-Version": {
                "$ref": "#/components/headers/StockPairApiVersion"
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": true
                }
              }
            }
          },
          "400": {
            "description": "Invalid bounded query",
            "headers": {
              "X-StockPair-API-Version": {
                "$ref": "#/components/headers/StockPairApiVersion"
              }
            }
          },
          "404": {
            "description": "Evidence unavailable",
            "headers": {
              "X-StockPair-API-Version": {
                "$ref": "#/components/headers/StockPairApiVersion"
              }
            }
          }
        },
        "parameters": [
          {
            "name": "chainId",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer",
              "minimum": 1
            }
          },
          {
            "name": "address",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "pattern": "^0x[0-9a-fA-F]{40}$"
            }
          }
        ]
      }
    },
