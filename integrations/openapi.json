    "/api/robinhood/account-abstraction": {
      "get": {
        "summary": "Return EntryPoint generations, EIP-7702 support and a disabled-by-default bounded policy",
        "responses": {
          "200": {
            "description": "Return EntryPoint generations, EIP-7702 support and a disabled-by-default bounded policy",
            "headers": {
              "X-StockPair-API-Version": {
                "$ref": "#/components/headers/StockPairApiVersion"
              }
            }
