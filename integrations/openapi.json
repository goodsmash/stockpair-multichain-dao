{
  "openapi": "3.1.0",
  "info": {
    "title": "StockPair Robinhood Chain Intelligence API",
    "version": "0.9.0",
    "description": "Read-only multi-chain contract, token, DEX, wallet, DAO/governance and Robinhood-native intelligence APIs. This API never accepts private keys, signs, broadcasts, claims token safety, or authorizes governance or treasury recovery."
  },
  "servers": [
    {
      "url": "https://indexer.example.com",
      "description": "Production indexer"
    },
    {
      "url": "http://127.0.0.1:8787",
      "description": "Disposable local demo"
    }
  ],
  "paths": {
    "/health": {
      "get": {
        "summary": "Service and chain health",
        "responses": {
          "200": {
            "description": "Healthy or degraded service state",
            "headers": {
              "X-StockPair-API-Version": {
                "$ref": "#/components/headers/StockPairApiVersion"
              }
            }
          }
        }
      }
    },
    "/api/radar/sources": {
      "get": {
        "summary": "List built-in launch-source adapter descriptors",
        "responses": {
          "200": {
            "description": "Adapter descriptors",
            "headers": {
              "X-StockPair-API-Version": {
                "$ref": "#/components/headers/StockPairApiVersion"
              }
            }
          }
        }
      }
    },
    "/api/radar/candidates": {
      "get": {
        "summary": "Rank normalized launch candidates",
        "parameters": [
          {
            "name": "chainId",
            "in": "query",
            "schema": {
              "type": "integer",
              "minimum": 1
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 500,
              "default": 100
            }
          },
          {
            "name": "stage",
            "in": "query",
            "schema": {
              "enum": [
                "detected",
                "curve",
                "pooled",
                "graduated",
                "active"
              ]
            }
          },
          {
            "name": "minScore",
            "in": "query",
            "schema": {
              "type": "number",
              "minimum": 0,
              "maximum": 100
            }
          },
          {
            "name": "maxRiskScore",
            "in": "query",
            "schema": {
              "type": "number",
              "minimum": 0,
              "maximum": 100
            }
          },
          {
            "name": "q",
            "in": "query",
            "schema": {
              "type": "string",
              "maxLength": 160
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Ranked candidates",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
                    "generatedAt",
                    "count",
                    "total",
                    "policy",
                    "candidates"
                  ],
                  "properties": {
                    "generatedAt": {
                      "type": "string",
                      "format": "date-time"
                    },
                    "count": {
                      "type": "integer"
                    },
                    "total": {
                      "type": "integer"
                    },
                    "policy": {
                      "type": "object"
                    },
                    "candidates": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/LaunchCandidate"
                      }
                    }
                  }
                }
              }
            },
            "headers": {
              "X-StockPair-API-Version": {
                "$ref": "#/components/headers/StockPairApiVersion"
              }
            }
          }
        }
      }
    },
    "/api/radar/alerts": {
      "get": {
        "summary": "Evaluate configured alert rules against the current radar snapshot",
        "parameters": [
          {
            "name": "chainId",
            "in": "query",
            "schema": {
              "type": "integer",
              "minimum": 1
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 500,
              "default": 100
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Matched rules and candidates",
            "headers": {
              "X-StockPair-API-Version": {
                "$ref": "#/components/headers/StockPairApiVersion"
              }
            }
          }
        }
      }
    },
    "/api/scout/summary": {
      "get": {
        "summary": "Scout coverage and counts",
        "responses": {
          "200": {
            "description": "Coverage summary",
            "headers": {
              "X-StockPair-API-Version": {
                "$ref": "#/components/headers/StockPairApiVersion"
              }
            }
          }
        }
      }
    },
    "/api/scout/tokens": {
      "get": {
        "summary": "Raw detected ERC-20-like contracts",
